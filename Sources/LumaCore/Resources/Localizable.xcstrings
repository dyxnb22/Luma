{
  "sourceLanguage": "en",
  "strings": {
    "settings.language.system": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "System Language"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "跟随系统"
          }
        }
      }
    },
    "settings.language.title": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Language"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "语言"
          }
        }
      }
    },
    "search.empty.typeToSearch": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Type to search apps, commands, and modules"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "输入以搜索应用、命令和模块"
          }
        }
      }
    },
    "search.empty.help": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Type help <command> for help (e.g. help clip). clip ? also works."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "输入 help <命令> 查看帮助（如 help clip）。也可使用 clip ?"
          }
        }
      }
    },
    "search.empty.pressEscClear": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Press Esc to clear."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "按 Esc 清除。"
          }
        }
      }
    },
    "search.empty.noItemsInSection": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "No items in %@. Add data or try a more specific query."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ 中暂无内容。请添加数据或缩小查询范围。"
          }
        }
      }
    },
    "search.empty.noMatchesInSection": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "No matches in %@ for “%@”. Check spelling or module settings."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在 %@ 中未找到 “%@”。请检查拼写或模块设置。"
          }
        }
      }
    },
    "search.empty.unknownDidYouMean": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Unknown command “%@”. Did you mean %@?"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "未知命令 “%@”。是否指 %@？"
          }
        }
      }
    },
    "search.empty.unknownHelp": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Unknown command “%@”. Try help %@ or type ? for all commands."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "未知命令 “%@”。试试 help %@ 或输入 ? 查看全部命令。"
          }
        }
      }
    },
    "search.empty.globalMinChars": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Type at least 2 characters for global search, or use a command prefix (clip, note, t)."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "全局搜索至少输入 2 个字符，或使用命令前缀（clip、note、t）。"
          }
        }
      }
    },
    "search.empty.globalNoMatches": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "No matches for “%@”. Enable modules in Settings or try a command prefix."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "未找到 “%@”。请在设置中启用模块或尝试命令前缀。"
          }
        }
      }
    },
    "search.empty.suggestion": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Select a suggestion or press Return"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "选择建议项或按 Return"
          }
        }
      }
    },
    "search.placeholder.cheatSheet": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Search apps, paste, translate, todo, aw…"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "搜索应用、剪贴板、翻译、待办、aw…"
